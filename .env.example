# Copy this file to .env and fill in your keys
# .env is gitignored and will NOT be pushed to the repo

# Google Scholar ID (required)
SCHOLAR_ID=hgN6B6kAAAAJ

# LLM for publication classification (optional, for --classify flag)
# Set the key for your provider — provider is auto-detected from which key is set
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Model override (optional, default: auto per provider)
model=
