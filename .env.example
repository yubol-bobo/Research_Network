# Copy this file to .env and fill in your keys
# .env is gitignored and will NOT be pushed to the repo

# Google Scholar ID (required)
SCHOLAR_ID=YOUR_SCHOLAR_ID

# LLM API key (required — set one, provider is auto-detected)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Model override (optional, default: auto per provider)
model=
